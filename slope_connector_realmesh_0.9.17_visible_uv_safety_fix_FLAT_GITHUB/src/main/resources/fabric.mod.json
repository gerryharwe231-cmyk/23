{
  "schemaVersion": 1,
  "id": "slopeconnector_arc_hotfix",
  "version": "${version}",
  "name": "Slope Connector Connected Model Sweep",
  "description": "Preserves original baked-model geometry and UVs when bending full blocks, fences, panes, walls, railings and Conquest Reforged balustrades along real arc paths.",
  "authors": ["OpenAI"],
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": ["com.slopeconnector.hotfix.ArcHotfixMod"],
    "client": ["com.slopeconnector.hotfix.client.ArcHotfixClient"]
  },
  "mixins": ["slopeconnector_arc_hotfix.mixins.json"],
  "jars": [{"file": "META-INF/jars/slopeconnector-0.9.10.jar"}],
  "depends": {
    "fabricloader": ">=0.16.0",
    "fabric-api": "*",
    "minecraft": "~1.20.1",
    "java": ">=17",
    "slopeconnector": "=0.9.10-endpoint-symmetry-fix"
  }
}
